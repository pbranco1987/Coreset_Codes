# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg

# ── Virtual environments ──
venv/
.venv/
env/

# ── Jupyter ──
.ipynb_checkpoints/

# ── IDE / OS ──
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
NUL

# ── Experiment outputs (large, regenerable) ──
EXPERIMENTS-*/
replicate_cache*/
runs_out*/
bootstrap_results/
bootstrap_reports/
logs/

# ── Data files (large — see README for download instructions) ──
data/*.hdf5
data/*.csv
data/*.parquet
*.npz

